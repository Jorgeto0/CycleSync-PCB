	)
	(text "BACKUP-DOMAIN NOTES\n\nBT1 MUST BE A RECHARGEABLE VL-2330/HFN CELL.\nDO NOT SUBSTITUTE A PRIMARY COIN CELL.\n\nR21 = 1 kΩ LIMITS CELL CHARGE CURRENT.\nU3 BLOCKS BT1 BACKFEED INTO +3V3_GNSS.\nU4 QOD IS INTENTIONALLY CONNECTED TO OUT.\nV_BCKP MUST RISE BEFORE OR WITH U2 VCC.\n\nGPIO12 HIGH = BACKUP OFF.\nGPIO12 LOW OR HI-Z = BACKUP ON."
		(exclude_from_sim no)
		(at 149.606 141.986 0)
		(effects
			(font
				(size 0.889 0.889)
			)
		)
		(uuid "94f32446-7d70-4e4e-b9ba-0ddc128122c0")
	)
	(text "RF POPULATION OPTIONS\n\nDEFAULT:\nFIT R11-R14 = 0 Ω.\nDNP C16, C17, R15, R16, L1, L2, J2, FL1.\n\nVNA TEST:\nDNP R12; FIT J2.\n\nSAW FILTER:\nDNP R13 AND R14.\nFIT FL1 AND FIT R15/R16 = 0 Ω.\nKEEP L1/L2 DNP."
		(exclude_from_sim no)
		(at 31.75 101.6 0)
		(effects
			(font
				(size 1.016 1.016)
			)
		)
		(uuid "fd33da48-44d7-4328-bbde-2f1f4212a6c9")
	)
